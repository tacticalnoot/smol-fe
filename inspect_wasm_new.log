 • Function: verify_and_attest
     Docs: Verify a Groth16 proof and store the tier attestation on-chain.
           
           This performs the full Groth16 pairing check:
           e(pi_a, pi_b) == e(alpha, beta) * e(vk_x, gamma) * e(pi_c, delta)
           
           Which is equivalent to checking:
           e(-pi_a, pi_b) * e(alpha, beta) * e(vk_x, gamma) * e(pi_c, delta) == 1
           
           Where vk_x = IC[0] + sum(pub_input[i] * IC[i+1])
           
           # Arguments
           * `farmer` - Address of the farmer (requires auth)
           * `tier` - Claimed tier (0-3, public input to circuit)
           * `commitment` - Poseidon commitment (public input to circuit)
           * `proof` - The Groth16 proof (pi_a, pi_b, pi_c)
     Inputs: VecM(
         [
             ScSpecFunctionInputV0 {
                 doc: StringM(),
                 name: StringM(farmer),
                 type_: Address,
             },
             ScSpecFunctionInputV0 {
                 doc: StringM(),
                 name: StringM(tier),
                 type_: U32,
             },
             ScSpecFunctionInputV0 {
                 doc: StringM(),
                 name: StringM(commitment),
                 type_: BytesN(
                     ScSpecTypeBytesN {
                         n: 32,
                     },
                 ),
             },
             ScSpecFunctionInputV0 {
                 doc: StringM(),
                 name: StringM(proof),
                 type_: Udt(
                     ScSpecTypeUdt {
                         name: StringM(Groth16Proof),
                     },
                 ),
             },
         ],
     )
     Output: VecM(
         [
             Result(
                 ScSpecTypeResult {
                     ok_type: Bool,
                     error_type: Udt(
                         ScSpecTypeUdt {
                             name: StringM(TierVerifierError),
                         },
                     ),
                 },
             ),
         ],
     )


