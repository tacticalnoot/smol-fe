---
// Fullscreen embed — drops directly into the ZK Dungeon game.
const TARGET =
  import.meta.env.PUBLIC_ZK_DUNGEON_URL ??
  "/labs/the-farm/play";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>ZK Dungeon | The Farm</title>
    <meta name="description" content="Jump straight into the live ZK Dungeon game — every door is a proof on Stellar." />
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet" />
    <style>
      :root { color-scheme: dark; }
      body {
        margin: 0;
        background: #04060b;
        color: #e8f0ff;
        display: grid;
        place-items: center;
        min-height: 100vh;
        font-family: "Inter", system-ui, -apple-system, sans-serif;
      }
      .frame {
        width: 100vw;
        height: 100vh;
        border: none;
      }
      .fallback {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: #04060b;
        color: #e8f0ff;
        text-align: center;
        padding: 24px;
        gap: 16px;
      }
      .fallback-badge {
        font-family: "Press Start 2P", monospace;
        font-size: 9px;
        letter-spacing: 3px;
        color: #4ad0ff;
        padding: 6px 14px;
        border: 1px solid rgba(74, 208, 255, 0.2);
        border-radius: 999px;
      }
      .fallback h1 {
        font-family: "Press Start 2P", monospace;
        font-size: clamp(14px, 3vw, 20px);
        letter-spacing: 2px;
        margin: 0;
      }
      .cta {
        display: inline-block;
        padding: 14px 28px;
        border-radius: 10px;
        border: 1px solid rgba(255, 255, 255, 0.2);
        text-decoration: none;
        color: #0a0c16;
        background: linear-gradient(135deg, #4ad0ff, #9b7bff 60%);
        font-family: "Press Start 2P", monospace;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 2px;
        box-shadow: 0 6px 24px rgba(74, 208, 255, 0.25);
      }
    </style>
  </head>
  <body>
    <iframe class="frame" src={TARGET} allowfullscreen title="ZK Dungeon"></iframe>
    <div class="fallback">
      <span class="fallback-badge">CHAPTER 3</span>
      <h1>STELLAR ZK DUNGEON</h1>
      <a class="cta" href={TARGET}>PLAY NOW</a>
    </div>
  </body>
</html>
