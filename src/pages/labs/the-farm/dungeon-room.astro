---
// Chapter 3: Stellar ZK Dungeon — AAA game studio landing page
const GAME_TARGET =
  import.meta.env.PUBLIC_ZK_DUNGEON_URL ?? "/labs/the-farm/play";
const HUB_CONTRACT = "CB4VZAT2U3UC6XFK3N23SKRF2NDCMP3QHJYMCHHFMZO7MRQO6DQ2EMYG";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Chapter 3: Stellar ZK Dungeon | The Farm</title>
    <meta name="description" content="10 floors, 4 doors, every choice a ZK proof on Stellar. The flagship multiplayer dungeon from The Farm." />
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet" />
    <style>
      :root {
        color-scheme: dark;
        --color-bg: #03040a;
        --color-surface: rgba(10, 13, 22, 0.82);
        --color-border: rgba(255, 255, 255, 0.08);
        --color-text: #e8f0ff;
        --color-dim: #7b96bf;
        --color-accent: #4ad0ff;
        --color-accent2: #9b7bff;
        --color-accent3: #ffc47a;
        --font-display: "Press Start 2P", monospace;
        --font-body: "Inter", system-ui, -apple-system, sans-serif;
      }
      *, *::before, *::after { box-sizing: border-box; }
      body {
        margin: 0;
        background: var(--color-bg);
        color: var(--color-text);
        font-family: var(--font-body);
        overflow-x: hidden;
      }

      /* ── Canvas Background ─────────────────────────────────────── */
      canvas {
        position: fixed;
        inset: 0;
        width: 100vw;
        height: 100vh;
        z-index: 0;
        pointer-events: none;
      }

      /* ── Hero Section ──────────────────────────────────────────── */
      .hero {
        position: relative;
        z-index: 1;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 40px 24px;
      }

      .hero-badge {
        font-family: var(--font-display);
        font-size: 9px;
        letter-spacing: 4px;
        text-transform: uppercase;
        color: var(--color-accent);
        margin: 0 0 20px;
        padding: 8px 18px;
        border: 1px solid rgba(74, 208, 255, 0.2);
        border-radius: 999px;
        background: rgba(74, 208, 255, 0.04);
      }

      .hero-title {
        font-family: var(--font-display);
        font-size: clamp(20px, 5vw, 40px);
        letter-spacing: 3px;
        line-height: 1.4;
        margin: 0 0 16px;
        background: linear-gradient(135deg, var(--color-text) 20%, var(--color-accent) 80%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .hero-subtitle {
        font-size: clamp(14px, 2vw, 18px);
        color: var(--color-dim);
        max-width: 560px;
        line-height: 1.7;
        margin: 0 0 36px;
      }

      .hero-cta-group {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 14px;
      }

      .cta-play {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        padding: 18px 40px;
        border-radius: 12px;
        border: 1px solid rgba(255, 255, 255, 0.2);
        text-decoration: none;
        color: #0a0c16;
        background: linear-gradient(135deg, var(--color-accent), var(--color-accent2) 70%);
        font-family: var(--font-display);
        font-size: 13px;
        font-weight: 800;
        letter-spacing: 3px;
        box-shadow:
          0 8px 32px rgba(74, 208, 255, 0.25),
          0 0 60px rgba(155, 123, 255, 0.1);
        transition: all 0.3s ease;
        cursor: pointer;
      }
      .cta-play:hover {
        transform: translateY(-2px);
        box-shadow:
          0 12px 44px rgba(74, 208, 255, 0.35),
          0 0 80px rgba(155, 123, 255, 0.15);
      }

      .cta-play-arrow {
        font-size: 18px;
        line-height: 1;
      }

      .cta-secondary-row {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        justify-content: center;
      }

      .cta-secondary {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 10px 18px;
        border-radius: 8px;
        border: 1px solid var(--color-border);
        background: var(--color-surface);
        color: var(--color-dim);
        font-family: var(--font-display);
        font-size: 8px;
        letter-spacing: 1.5px;
        text-decoration: none;
        transition: all 0.2s ease;
        cursor: pointer;
      }
      .cta-secondary:hover {
        border-color: rgba(255, 255, 255, 0.18);
        color: var(--color-text);
        background: rgba(255, 255, 255, 0.04);
      }

      /* ── Features Section ──────────────────────────────────────── */
      .features {
        position: relative;
        z-index: 1;
        padding: 60px 24px 80px;
        max-width: 900px;
        margin: 0 auto;
      }

      .features-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 20px;
      }

      .feature-card {
        padding: 24px;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 14px;
        transition: border-color 0.2s;
      }
      .feature-card:hover {
        border-color: rgba(255, 255, 255, 0.15);
      }

      .feature-icon {
        font-size: 24px;
        margin-bottom: 14px;
        display: block;
      }

      .feature-title {
        font-family: var(--font-display);
        font-size: 10px;
        letter-spacing: 1.5px;
        margin: 0 0 8px;
      }

      .feature-desc {
        font-size: 13px;
        color: var(--color-dim);
        line-height: 1.6;
        margin: 0;
      }

      /* ── Tech Stack Section ────────────────────────────────────── */
      .tech-section {
        position: relative;
        z-index: 1;
        padding: 0 24px 80px;
        max-width: 900px;
        margin: 0 auto;
      }

      .tech-label {
        font-family: var(--font-display);
        font-size: 9px;
        letter-spacing: 3px;
        color: var(--color-dim);
        text-align: center;
        margin: 0 0 24px;
      }

      .tech-pills {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        justify-content: center;
      }

      .tech-pill {
        font-family: var(--font-display);
        font-size: 9px;
        letter-spacing: 1px;
        padding: 8px 16px;
        border-radius: 8px;
        border: 1px solid var(--color-border);
        background: var(--color-surface);
      }

      .tech-pill-noir { color: var(--color-accent); border-color: rgba(74, 208, 255, 0.2); }
      .tech-pill-circom { color: var(--color-accent3); border-color: rgba(255, 196, 122, 0.2); }
      .tech-pill-risc0 { color: var(--color-accent2); border-color: rgba(155, 123, 255, 0.2); }
      .tech-pill-stellar { color: #7bffb0; border-color: rgba(123, 255, 176, 0.2); }
      .tech-pill-passkey { color: #ff9bcd; border-color: rgba(255, 155, 205, 0.2); }

      /* ── Footer ────────────────────────────────────────────────── */
      .page-footer {
        position: relative;
        z-index: 1;
        padding: 24px;
        text-align: center;
        border-top: 1px solid var(--color-border);
      }

      .footer-hub {
        font-family: var(--font-display);
        font-size: 7px;
        color: var(--color-dim);
        letter-spacing: 1px;
        margin: 0 0 8px;
        word-break: break-all;
      }

      .footer-links {
        display: flex;
        gap: 16px;
        justify-content: center;
        flex-wrap: wrap;
      }

      .footer-link {
        font-family: var(--font-display);
        font-size: 8px;
        letter-spacing: 1.5px;
        color: var(--color-dim);
        text-decoration: none;
        transition: color 0.2s;
      }
      .footer-link:hover { color: var(--color-accent); }

      /* ── Scroll indicator ──────────────────────────────────────── */
      .scroll-hint {
        position: absolute;
        bottom: 32px;
        left: 50%;
        transform: translateX(-50%);
        font-family: var(--font-display);
        font-size: 8px;
        color: rgba(255, 255, 255, 0.2);
        letter-spacing: 2px;
        animation: fade-bounce 2s ease-in-out infinite;
      }

      @keyframes fade-bounce {
        0%, 100% { opacity: 0.2; transform: translateX(-50%) translateY(0); }
        50% { opacity: 0.5; transform: translateX(-50%) translateY(6px); }
      }
    </style>
  </head>
  <body>
    <canvas id="portal"></canvas>

    <!-- Hero -->
    <section class="hero">
      <p class="hero-badge">THE FARM &middot; CHAPTER 3</p>
      <h1 class="hero-title">STELLAR ZK DUNGEON</h1>
      <p class="hero-subtitle">
        Two players. Ten sealed floors. Four rune doors per chamber.
        Every choice generates a real zero-knowledge proof verified on Stellar.
        Wrong doors still verify &mdash; your secret stays hidden either way.
      </p>
      <div class="hero-cta-group">
        <a class="cta-play" href={GAME_TARGET}>
          <span>PLAY NOW</span>
          <span class="cta-play-arrow">&rsaquo;</span>
        </a>
        <div class="cta-secondary-row">
          <a class="cta-secondary" href="/labs/the-farm">DASHBOARD</a>
          <button class="cta-secondary" id="how-btn" type="button">HOW IT WORKS</button>
          <a class="cta-secondary" href={`https://stellar.expert/explorer/testnet/contract/${HUB_CONTRACT}`} target="_blank" rel="noreferrer">ON-CHAIN</a>
        </div>
      </div>
      <span class="scroll-hint">SCROLL</span>
    </section>

    <!-- Features -->
    <section class="features" id="how-it-works">
      <div class="features-grid">
        <div class="feature-card">
          <span class="feature-icon">&loz;</span>
          <h3 class="feature-title">REAL ZK PROOFS</h3>
          <p class="feature-desc">
            Noir circuits generate proofs in your browser. Circom gates and a RISC Zero boss
            round add multi-framework variety. Every proof is verified on-chain.
          </p>
        </div>
        <div class="feature-card">
          <span class="feature-icon">&diams;</span>
          <h3 class="feature-title">2-PLAYER CO-OP</h3>
          <p class="feature-desc">
            Create a lobby, share a code. Co-op gates on floors 1 & 5 force synchronization.
            Race to the boss on floor 10 together.
          </p>
        </div>
        <div class="feature-card">
          <span class="feature-icon">&spades;</span>
          <h3 class="feature-title">ON-CHAIN EVIDENCE</h3>
          <p class="feature-desc">
            start_game() and end_game() calls hit the Stellar game hub.
            Every attempt is an on-chain transaction with proof verification and is_correct output.
          </p>
        </div>
        <div class="feature-card">
          <span class="feature-icon">&clubs;</span>
          <h3 class="feature-title">ZERO FRICTION</h3>
          <p class="feature-desc">
            Passkey smart account by default — one tap to start. No browser extension,
            no seed phrase. Judges just click "Play."
          </p>
        </div>
        <div class="feature-card">
          <span class="feature-icon">&hearts;</span>
          <h3 class="feature-title">WRONG = STILL VALID</h3>
          <p class="feature-desc">
            Picking the wrong door generates a valid proof that verifies on-chain with is_correct=0.
            The circuit never fails — only the outcome differs.
          </p>
        </div>
        <div class="feature-card">
          <span class="feature-icon">&star;</span>
          <h3 class="feature-title">RUN LOG</h3>
          <p class="feature-desc">
            Live in-game log shows every attempt: floor, door, proof type, tx hash link,
            and result. Full evidence dashboard after the run.
          </p>
        </div>
      </div>
    </section>

    <!-- Tech -->
    <section class="tech-section">
      <p class="tech-label">POWERED BY</p>
      <div class="tech-pills">
        <span class="tech-pill tech-pill-noir">NOIR</span>
        <span class="tech-pill tech-pill-circom">CIRCOM</span>
        <span class="tech-pill tech-pill-risc0">RISC ZERO</span>
        <span class="tech-pill tech-pill-stellar">STELLAR SOROBAN</span>
        <span class="tech-pill tech-pill-passkey">PASSKEY WALLET</span>
      </div>
    </section>

    <!-- Footer -->
    <footer class="page-footer">
      <p class="footer-hub">HUB: {HUB_CONTRACT}</p>
      <div class="footer-links">
        <a class="footer-link" href="/labs/the-farm">THE FARM</a>
        <a class="footer-link" href="/labs">ALL LABS</a>
        <a class="footer-link" href="https://github.com/tacticalnoot/smol-fe" target="_blank" rel="noreferrer">SOURCE</a>
      </div>
    </footer>

    <script type="module">
      const GAME_TARGET = ${JSON.stringify(GAME_TARGET)};

      // How it works scroll
      document.getElementById("how-btn")?.addEventListener("click", () => {
        document.getElementById("how-it-works")?.scrollIntoView({ behavior: "smooth" });
      });

      // Animated canvas
      const canvas = document.getElementById("portal");
      const ctx = canvas.getContext("2d");
      const DPR = Math.min(window.devicePixelRatio || 1, 1.75);
      let w, h, t = 0;

      const resize = () => {
        w = canvas.width = innerWidth * DPR;
        h = canvas.height = innerHeight * DPR;
      };
      resize();
      window.addEventListener("resize", resize);

      const stars = Array.from({ length: 160 }, () => ({
        x: Math.random(),
        y: Math.random(),
        z: Math.random(),
        s: 0.4 + Math.random() * 1.6,
      }));

      function draw() {
        t += 0.002;
        ctx.clearRect(0, 0, w, h);

        // Nebula gradient
        const g = ctx.createRadialGradient(w * 0.5, h * 0.25, w * 0.02, w * 0.5, h * 0.4, w * 0.85);
        g.addColorStop(0, "rgba(74, 120, 255, 0.2)");
        g.addColorStop(0.4, "rgba(155, 80, 255, 0.08)");
        g.addColorStop(1, "rgba(5, 7, 13, 0.05)");
        ctx.fillStyle = g;
        ctx.fillRect(0, 0, w, h);

        // Subtle grid
        ctx.save();
        ctx.translate(w * 0.5, h * 0.85);
        ctx.strokeStyle = "rgba(74, 208, 255, 0.06)";
        ctx.lineWidth = 0.8 * DPR;
        for (let i = -24; i <= 24; i++) {
          ctx.beginPath();
          ctx.moveTo(i * 36, 0);
          ctx.lineTo(i * 36, -h * 0.7);
          ctx.stroke();
        }
        for (let j = 0; j < 20; j++) {
          const y = -j * 36;
          ctx.beginPath();
          ctx.moveTo(-w, y);
          ctx.lineTo(w, y);
          ctx.stroke();
        }
        ctx.restore();

        // Pulse ring
        ctx.save();
        ctx.translate(w * 0.5, h * 0.35);
        const r = (Math.sin(t * 1.5) * 0.5 + 0.5) * 100 + 150;
        const ring = ctx.createRadialGradient(0, 0, r * 0.3, 0, 0, r);
        ring.addColorStop(0, "rgba(74, 208, 255, 0.1)");
        ring.addColorStop(0.5, "rgba(155, 123, 255, 0.06)");
        ring.addColorStop(1, "rgba(82, 255, 201, 0)");
        ctx.fillStyle = ring;
        ctx.beginPath();
        ctx.arc(0, 0, r, 0, Math.PI * 2);
        ctx.fill();
        ctx.restore();

        // Stars
        for (const s of stars) {
          s.z -= 0.002;
          if (s.z < 0.01) s.z = 1;
          const x = ((s.x - 0.5) * w * 0.9) / s.z + w * 0.5;
          const y = ((s.y - 0.5) * h * 0.7) / s.z + h * 0.35;
          const size = (1.2 - s.z) * s.s * DPR;
          const alpha = (1 - s.z) * 0.7 + 0.1;
          ctx.fillStyle = `rgba(255, 255, 255, ${alpha})`;
          ctx.fillRect(x, y, size, size);
        }

        requestAnimationFrame(draw);
      }
      requestAnimationFrame(draw);
    </script>
  </body>
</html>
