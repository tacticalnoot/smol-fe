---
import Layout from "../../../layouts/Layout.astro";
import ZkDungeonGame from "../../../components/labs/the-farm/dungeon/ZkDungeonGame.svelte";
---

<Layout title="ZK Dungeon — The Farm | Chapter 3" description="10 floors, 4 doors, every choice is a ZK proof on Stellar. Play the Stellar ZK Dungeon.">
  <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet" />

  <div class="dungeon-game-wrapper">
    <ZkDungeonGame client:only="svelte" />
  </div>
</Layout>

<style is:global>
  .dungeon-game-wrapper {
    position: fixed;
    inset: 0;
    z-index: 9999;
  }

  .dungeon-game-wrapper ~ header,
  .dungeon-game-wrapper ~ nav,
  .dungeon-game-wrapper ~ footer {
    display: none !important;
  }
</style>
