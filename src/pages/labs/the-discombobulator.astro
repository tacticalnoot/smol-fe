---
import Layout from "../../layouts/Layout.astro";
import DiscombobulatorCore from "../../components/labs/DiscombobulatorCore.svelte";
import KaleForestScene from "../../components/labs/KaleForestScene.svelte";

// LABS-101: Shell Only
const debugMode = Astro.url.searchParams.has("debug");
const lowGpuMode =
  debugMode || Astro.url.searchParams.get("gpu") === "lite";
---

<Layout title="The Discombobulator | Smol Labs">
  <!-- Google Fonts import -->
  <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">

  <!-- Transparent Wrapper (Global Scene is Behind) -->
  <div class="fixed inset-0 text-[#9ae600] overflow-hidden flex flex-col items-center justify-center pointer-events-none" style="font-family: 'Press Start 2P', cursive;">

    <!-- Global Background Scene (Fixed) -->
    <div class="fixed inset-0 z-0 pointer-events-auto">
        {
            lowGpuMode ? (
                <div
                    class="absolute inset-0 bg-cover bg-center"
                    style="background-image: url('/kale-forest-bg-v2.jpg');"
                />
            ) : (
                <KaleForestScene client:load />
            )
        }
        {lowGpuMode && (
            <div class="absolute top-3 right-3 z-20 text-[8px] md:text-[9px] uppercase tracking-[0.2em] text-[#fdda24] bg-black/70 border border-[#fdda24]/40 rounded-full px-2 py-1">
                GPU-Safe Debug Scene
            </div>
        )}
    </div>
    
    <!-- Nav Back -->
    <a href="/labs" class="absolute top-4 left-4 md:top-8 md:left-8 z-30 text-[10px] md:text-xs uppercase tracking-widest text-[#5a8a5a] hover:text-[#9ae600] flex items-center gap-2 transition-colors pointer-events-auto">
        <span>&larr; LABS</span>
    </a>

    <!-- Main Content (Floating) -->
    <div class="relative z-10 w-full max-w-lg flex flex-col gap-4 md:gap-6 items-center text-center px-4 pointer-events-auto pb-4 md:pb-0">
        
        <!-- Header (Floating over Forest) -->
        <div class="space-y-3 md:space-y-4">
            <h1 class="text-2xl md:text-4xl font-black tracking-tighter drop-shadow-[4px_4px_0_rgba(0,0,0,0.8)] leading-tight">
                <span class="text-[#94db03]">The</span><span class="text-white"> Discombobulator</span>
            </h1>
            <p class="text-[8px] md:text-[10px] text-[#fdda24] tracking-[0.15em] bg-black/40 px-3 py-1 rounded-full border border-[#fdda24]/30 inline-block backdrop-blur-sm">
                Nethermind SPP Mainnet Console (Labs)
            </p>
            <p class="text-[7px] md:text-[8px] text-[#cbd5e1] tracking-[0.08em] bg-black/30 px-3 py-2 rounded-xl border border-white/10 inline-block backdrop-blur-sm">
                Mainnet-safe SPP execution with public settlement, ASP policy checks, commitment receipts, and selective-disclosure artifacts.
            </p>
        </div>

        <!-- Svelte Interactive Component -->
        <div class="w-full">
            <DiscombobulatorCore client:only="svelte" />
        </div>

    </div>

  </div>
</Layout>


