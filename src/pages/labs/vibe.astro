---
import Layout from "../../layouts/Layout.astro";
import BackLink from "../../components/labs/BackLink.astro";
import VibePet from "../../components/labs/vibe/VibePet.svelte";
import { SMOL_IDENTITY } from "../../utils/seo-schema";

const schema = [{
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "The Vibe",
    "description": "A persistent, audio-reactive desktop pet that lives in the Smol Labs.",
    "genre": "Virtual Pet",
    "applicationCategory": "Game",
    "operatingSystem": "Web Browser",
    "url": "https://noot.smol.xyz/labs/vibe",
    "author": SMOL_IDENTITY,
    "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD",
        "availability": "https://schema.org/InStock"
    }
}];
---

<Layout
    title="The Vibe | Smol Labs"
    description="Meet your new audio-reactive companion. Feed it KALE, play some tunes, and watch it vibe."
    schema={schema}
>
  <div class="min-h-screen bg-black text-white font-pixel p-4 md:p-8 pt-24 relative overflow-hidden">
    <!-- Background Grid Effect -->
    <div class="absolute inset-0 opacity-20 pointer-events-none">
        <div class="absolute inset-0 bg-[linear-gradient(rgba(18,18,18,0)_50%,rgba(0,0,0,0.25)_50%),linear-gradient(90deg,rgba(154,230,0,0.06),rgba(0,255,0,0.02),rgba(0,0,255,0.06))] z-10 bg-[length:100%_2px,3px_100%]"></div>
    </div>

    <div class="max-w-7xl mx-auto relative z-10 h-full flex flex-col justify-center gap-8">
      <BackLink href="/labs" />

      <!-- Main Game Container -->
      <div class="relative w-full max-w-4xl mx-auto aspect-video border-[4px] border-[#333] bg-[#0a0a0a] rounded-xl overflow-hidden shadow-[0_0_50px_rgba(154,230,0,0.1)] group">
        
        <!-- CRT/Scanline Overlay -->
        <div class="absolute inset-0 bg-[linear-gradient(rgba(18,16,16,0)_50%,rgba(0,0,0,0.25)_50%),linear-gradient(90deg,rgba(255,0,0,0.06),rgba(0,255,0,0.02),rgba(0,0,255,0.06))] z-20 bg-[length:100%_2px,3px_100%] pointer-events-none opacity-40"></div>
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_50%,rgba(0,0,0,0.6)_100%)] z-20 pointer-events-none"></div>

        <!-- The Pet Render Layer -->
        <div class="absolute inset-0 z-10">
            <VibePet client:only="svelte" />
        </div>

        <!-- Background (Retro Grid) -->
        <div class="absolute inset-0 opacity-30 pointer-events-none" 
             style="background-image: linear-gradient(#1a1a1a 1px, transparent 1px), linear-gradient(90deg, #1a1a1a 1px, transparent 1px); background-size: 40px 40px;">
        </div>

        <!-- HUD Layer -->
        <div class="absolute inset-0 z-30 pointer-events-none flex flex-col items-center justify-center select-none">
            <h1 class="text-6xl md:text-9xl font-bold font-pixel text-transparent stroke-text tracking-tighter opacity-10 mix-blend-overlay">
                THE VIBE
            </h1>
        </div>
      </div>

      <!-- Instructions Panel -->
      <div class="max-w-2xl mx-auto w-full p-6 border-2 border-[#333] rounded-xl bg-[#111]/90 backdrop-blur-md relative overflow-hidden group hover:border-[#9ae600]/30 transition-colors">
        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-[#9ae600] to-transparent opacity-20 group-hover:opacity-100 transition-opacity"></div>
        
        <h3 class="text-xl font-bold text-[#9ae600] mb-6 flex items-center gap-3 font-pixel tracking-widest">
            <span class="animate-pulse">●</span> SYSTEM ONLINE
        </h3>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 text-[10px] md:text-xs">
           <div class="space-y-4">
               <div>
                  <strong class="text-white block mb-1 uppercase tracking-wider">Interact</strong>
                  <p class="text-[#888]">Click the sprite to pet it. Don't let it get lonely.</p>
               </div>
               <div>
                  <strong class="text-white block mb-1 uppercase tracking-wider">Feed</strong>
                  <p class="text-[#888]">Use the HUD button to dispense KALE snacks.</p>
               </div>
           </div>
           <div class="space-y-4">
               <div>
                  <strong class="text-white block mb-1 uppercase tracking-wider">Audio Input</strong>
                  <p class="text-[#888]">Play music in another tab/window. The Vibe will sync to the beat.</p>
               </div>
               <div>
                   <strong class="text-white block mb-1 uppercase tracking-wider">Persistence</strong>
                   <p class="text-[#888]">State is saved locally. It will sleep if you leave it alone.</p>
               </div>
           </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap');
  
  .stroke-text {
    -webkit-text-stroke: 2px #9ae600;
  }
</style>
