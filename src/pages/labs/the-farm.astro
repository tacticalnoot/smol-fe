---
import Layout from "../../layouts/Layout.astro";
import TheFarmCore from "../../components/labs/the-farm/TheFarmCore.svelte";
import FarmSampleProofs from "../../components/labs/the-farm/FarmSampleProofs.svelte";
---

<Layout title="The Farm | Smol Labs" description="Proof of Farm — commit your KALE farming tier with a salted SHA-256 hash. Smart Wallet Dreamboard on Stellar.">
  <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">

  <div class="farm-page" style="font-family: 'Press Start 2P', cursive;">

    <!-- Nav Back -->
    <a href="/labs" class="absolute top-4 left-4 md:top-8 md:left-8 z-30 text-[10px] md:text-xs uppercase tracking-widest text-[#5a8a5a] hover:text-[#9ae600] flex items-center gap-2 transition-colors">
      <span>&larr; LABS</span>
    </a>

    <!-- TheFarmCore: original hero + full interactive game -->
    <div class="farm-core-wrapper">
      <TheFarmCore client:only="svelte" />
    </div>

    <!-- Quick Links: game routes added in recent commits -->
    <section class="quick-links">
      <h2 class="ql-heading">More Games</h2>
      <div class="ql-grid">

        <a href="/labs/the-farm/dungeon-room" class="ql-card">
          <h3 class="ql-card-title">ZK Dungeon</h3>
          <p class="ql-card-desc">10 floors of ZK-proven door choices. Every move is a Groth16 proof on Stellar.</p>
          <span class="ql-card-cta">Play &rarr;</span>
        </a>

        <a href="/labs/the-farm/client/play" class="ql-card">
          <h3 class="ql-card-title">Dungeon Client</h3>
          <p class="ql-card-desc">Launch the standalone game client with full-screen dungeon experience.</p>
          <span class="ql-card-cta">Play &rarr;</span>
        </a>

        <a href="/labs/the-farm/zkdungeon" class="ql-card">
          <h3 class="ql-card-title">ZK Dungeon Portal</h3>
          <p class="ql-card-desc">Quick-launch portal — jump straight into the dungeon from any device.</p>
          <span class="ql-card-cta">Play &rarr;</span>
        </a>

      </div>
    </section>

    <!-- Sample Proofs -->
    <div class="sample-proofs-wrapper">
      <FarmSampleProofs client:visible />
    </div>

  </div>
</Layout>

<style is:global>
  .farm-page {
    position: relative;
    width: 100%;
    min-height: 100vh;
    background: linear-gradient(170deg, #020617 0%, #041008 40%, #020617 100%);
  }

  .farm-core-wrapper {
    position: relative;
    z-index: 10;
    width: 100%;
  }

  /* ── Quick Links ── */
  .quick-links {
    position: relative;
    z-index: 10;
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    padding: 48px 20px;
  }

  .ql-heading {
    font-family: "Inter", system-ui, sans-serif;
    font-size: 28px;
    font-weight: 800;
    letter-spacing: -0.5px;
    color: #e8f2ff;
    margin: 0 0 24px;
  }

  .ql-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  @media (min-width: 640px) {
    .ql-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .ql-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .ql-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 20px;
    background: rgba(10, 18, 30, 0.8);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    text-decoration: none;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }

  .ql-card:hover {
    border-color: rgba(154, 230, 0, 0.4);
    box-shadow: 0 0 24px rgba(154, 230, 0, 0.08);
    transform: translateY(-2px);
  }

  .ql-card-title {
    font-family: "Inter", system-ui, sans-serif;
    font-size: 16px;
    font-weight: 700;
    color: #e8f2ff;
    margin: 0;
  }

  .ql-card-desc {
    font-family: "Inter", system-ui, sans-serif;
    font-size: 13px;
    color: #8899aa;
    line-height: 1.5;
    margin: 0;
    flex: 1;
  }

  .ql-card-cta {
    font-family: "Inter", system-ui, sans-serif;
    font-size: 12px;
    font-weight: 600;
    color: #9ae600;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    margin-top: 8px;
  }

  /* ── Sample Proofs Wrapper ── */
  .sample-proofs-wrapper {
    position: relative;
    z-index: 10;
    width: 100%;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }
</style>
